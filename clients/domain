#!/usr/bin/env ruby
# Enumerations
#
# listingType: Sale, Rent, Share, Sold, NewHomes
# propertyTypes: AcreageSemiRural, ApartmentUnitFlat, Aquaculture, BlockOfUnits, CarSpace, DairyFarming,
#     DevelopmentSite, Duplex, Farm, FishingForestry, NewHomeDesigns, House, NewHouseLand, IrrigationServices, NewLand,
#     Livestock, NewApartments, Penthouse, RetirementVillage, Rural, SemiDetached, SpecialistFarm, Studio, Terrace,
#     Townhouse, VacantLand, Villa, Cropping, Viticulture, MixedFarming, Grazing, Horticulture, Equine, Farmlet,
#     Orchard, RuralLifestyle
# propertyFeatures: AirConditioning, BuiltInWardrobes, CableOrSatellite, Ensuite, Floorboards, Gas, InternalLaundry,
#     PetsAllowed, SecureParking, SwimmingPool, Furnished, GroundFloor, WaterViews, NorthFacing, CityViews, IndoorSpa,
#     Gym, AlarmSystem, Intercom, BroadbandInternetAccess, Bath, Fireplace, SeparateDiningRoom, Heating, Dishwasher,
#     Study, TennisCourt, Shed, FullyFenced, BalconyDeck, GardenCourtyard, OutdoorSpa, DoubleGlazedWindows,
#     EnergyEfficientAppliances, WaterEfficientAppliances, WallCeilingInsulation, RainwaterStorageTank, GreywaterSystem,
#     WaterEfficientFixtures, SolarHotWater, SolarPanels
# listingAttributes: HasPhotos, HasPrice, NotUpForAuction, NotUnderContract, MarkedAsNew
# propertyEstablishedType: Any, New, Established
#
# Boolean flags
#
# newDevOnly, ruralOnly, excludePriceWithheld, excludeDepositTaken, includeInspectionAggregations
#
# Numeric fields
#
# minBedrooms, maxBedrooms
# minBathrooms, maxBathrooms
# minCarspaces, maxCarspaces,
# minPrice, maxPrice,
# minLandArea, maxLandArea
#
# Arrays of IDs
#
# advertiserIds
# adIds
# excludeAdIds
#
# Location fields
#
# locationTerms: string
# locations: Array of objects
#     state: [ACT, NSW, QLD, VIC, SA, WA, NT, TAS],
#     region: string
#     area: string
#     suburb: string
#     postCode: string
#     includeSurroundingSuburbs: boolean
#     surroundingRadiusInMeters: integer
# schoolCatchments: Array of objects (ignored)
#
# Date fields (RFC3339, e.g. "2016-12-19T16:30:00+11:00")
#
# updatedSince, listedSince, inspectionFrom, inspectionTo, auctionFrom, auctionTo, dateAvailableFrom, dateAvailableTo
#
# Pagination
#
# pageSize, pageNumber: number
# customSort: Object
#     elements: Array of objects
#         field: [AdId, PromoLevelScore, FreshnessLevel, ProductBoost, DateUpdated, DateListed, SuburbName,
#             PriceDisplayOption, SoldDate, Price, EarliestInspectionOpenTime, EarliestAuctionTime, DateAvailable]
#         direction: [Ascending, Descending]
#     boostPrimarySuburbs: boolean
# sort: Object
#     sortKey: [Default, Suburb, Price, DateUpdated, InspectionTime, AuctionTime, Proximity, SoldDate,
#         DefaultThenDateUpdated, DateAvailable, DateListed]
#     direction: [Ascending, Descending]
#     proximityTo: {lat:, lon:}
#
# Others
#
# keywords, topspotKeywords:	[string]
# geoWindow
#
require 'net/http'
require 'json'

DOMAIN_API_URL = URI("https://api.domain.com.au/v1/listings/residential/_search")
DOMAIN_API_KEY = ENV['DOMAIN_API_KEY']

DEFAULT_HEADERS = {
  'Content-Type' => 'application/json',
  'Transfer-Encoding' => 'chunked',
  'X-API-Key' => DOMAIN_API_KEY
}

def abort(message, status: 1)
  $stderr.puts(message)
  exit 1
end

def post(query, page_number: 1, page_size: 100)
  query['pageSize'] = page_size unless page_size.nil?
  query['pageNumber'] = page_number
  $stderr.puts 'Query:', '-' * 80, query, '-' * 80
  http = Net::HTTP.new(DOMAIN_API_URL.host, DOMAIN_API_URL.port)
  http.use_ssl = true
  request = Net::HTTP::Post.new(DOMAIN_API_URL.path, DEFAULT_HEADERS)
  sleep 1
  response = http.request(request, JSON.dump(query))
end

def handle_response(response, query:, output:)
case response
  when Net::HTTPSuccess
    $stderr.puts "Success: #{response.code} (#{response.class}) -- #{response.message}"

    # Debug
    response.each_capitalized do |header, value|
      $stderr.puts("#{header}: #{value}")
    end

    $stderr.puts('', '-' * 80, response.body, '-' * 80)

    # Get header X-Total-Count
    count = Integer(response.fetch('X-Total-Count'))

    # If it's lower than the page size (X-Pagination-Pagesize) times the (X-Pagination-Pagenumber),
    # we need to get the next page too
    page_size = Integer(response.fetch('X-Pagination-Pagesize'))
    page_number = Integer(response.fetch('X-Pagination-Pagenumber'))

    results = JSON.parse(response.body)
    $stderr.puts "count=#{count} results.count=#{results.count} page_size=#{page_size} page_number=#{page_number}"
    $stderr.puts("if results.count=#{results.count} > page_size=#{page_size}")

    results.pop while results.count > page_size
    output.puts(results.map { |result| JSON.dump(result) })

    # Domain API returns an error if you try to query past 1000 records total: "Cannot page beyond 1000 records"
    $stderr.puts("if (page_size * page_number)=#{page_size * page_number} >= 1000")
    if (page_size * (page_number + 1)) >= 1000
      $stderr.puts('Reached 1000 records, stopping')
      return
    end

    $stderr.puts("if count=#{count} > (page_size * page_number)=#{page_size * page_number}")
    if count > (page_size * page_number)
      $stderr.puts('Get next page')
      handle_response(post(query, page_number: page_number + 1), query:, output:)
    else
      $stderr.puts('Done')
    end
  else
    $stderr.puts "Error: #{response.code} (#{response.class}) -- #{response.message}"
    $stderr.puts response.body
    exit 1
  end
end

if ARGV.length != 2
  $stderr.puts "Usage: #{$0} input_file output_file"
  exit
end

input, output = ARGV

abort "File #{input} is not readable" unless File.readable?(input)
abort "File #{output} is not writable" if File.exist?(output) && !File.writable?(output)

$stderr.puts "Processing #{input} -> #{output}"

areas = [
  "Banyule Council - Greater Area",
  "Bayside - Greater Area",
  "Boorondara City Council - Greater Area",
  "Brimbank City Council - Greater Area",
  "Cardinia Shire - Greater Area",
  "Casey City - Greater Area",
  "Dandenong - Greater Area",
  "Darebin City Council - Greater Area",
  "Frankston Council - Greater Area",
  "Geelong & District - Greater Area",
  "Glen Eira Council - Greater Area",
  "Hobsons Bay City Council - Greater Area",
  "Hume City Council - Greater Area",
  "Kingston City Council - Greater Area",
  "Knox City - Greater Area",
  "Manningham City - Greater Area",
  "Maribyrnong City Council - Greater Area",
  "Maroondah City - Greater Area",
  "Melbourne City Council - Greater Area",
  "Melton City - Greater Area",
  "Monash City - Greater Area",
  "Monash Valley City Council - Greater Area",
  "Moreland City Council - Greater Area",
  "Mornington Peninsula & District - Greater Area",
  "Nillumbik Shire - Greater Area",
  "Port Philip City Council - Greater Area",
  "Stonnington - Greater Area",
  "Whitehorse City Council - Greater Area",
  "Whittlesea City Council - Greater Area",
  "Wyndham City Council - Greater Area",
  "Yarra City Council - Greater Area",
  "Yarra Ranges Shire - Greater Area",
].map do |name|
  {
    "state": "VIC",
    "area": name,
  }
end

query = File.open(input) { |file| JSON.load(file) }
File.open(output, 'w') do |file|
  areas.each_slice(2) do |areas|
    query['locations'] = areas

    response = post(query)
    handle_response(response, query:, output: file)
  end
end
