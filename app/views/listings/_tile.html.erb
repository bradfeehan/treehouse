<%= link_to listing_url(listing), class: 'block rounded-xl shadow-md overflow-hidden transition duration-300 ease-in-out transform hover:-translate-y-1 hover:shadow-lg' do %>
  <article class="flex flex-col">
    <div class="relative pb-2/3">
      <%= image_tag listing.image_url, class: 'absolute inset-0 w-full h-full object-cover' if listing.image? %>
    </div>
    <div class="flex-grow px-4 py-4">
      <h5 class="text-xl font-semibold mb-2 text-left"><%= render(listing.address || {plain: '[unknown address]'}) %></h5>
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-2 text-gray-500">
          <span class="flex items-center">
            <i class="fas fa-bed mr-1"></i><%= listing.bedroom_count %>
          </span>
          <span class="flex items-center">
            <i class="fas fa-bath mr-1"></i><%= listing.bathroom_count %>
          </span>
          <span class="flex items-center">
            <i class="fas fa-car mr-1"></i><%= listing.carpark_count %>
          </span>
        </div>
        <span class="text-2xl font-bold">
          <%= render(listing.price) %>
        </span>
      </div>
    </div>
  </article>
<% end %>
